# OpenAI API (recommended)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key-here

# Models — GPT-5 balanced: precision tasks use gpt-5, lighter tasks use gpt-5-mini
GENERATOR_MODEL=gpt-5-mini
JUDGE_MODEL=gpt-5
OPTIMIZER_MODEL=gpt-5
PREP_MODEL=gpt-5-mini

# Ollama (local, free)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# GENERATOR_MODEL=qwen2.5:14b
# JUDGE_MODEL=qwen2.5:14b
# OPTIMIZER_MODEL=qwen2.5:14b
# PREP_MODEL=qwen2.5:14b

# Optional controls
REQUEST_TIMEOUT_S=120
RANDOM_SEED=42
TRAIN_RATIO=0.7
DISABLE_LLM_CACHE=0

# Set to 1 for local smoke tests without a real API
MOCK_LLM=0
