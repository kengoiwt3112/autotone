# === LLM Provider ===
# "openai" (default, also works for Gemini/Ollama) or "anthropic"
LLM_PROVIDER=openai

# === OpenAI / Gemini / Ollama ===
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key-here

# --- Gemini example ---
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_API_KEY=your-gemini-api-key

# --- Ollama example ---
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama

# === Anthropic ===
# Set LLM_PROVIDER=anthropic to use Claude models
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Models (leave empty or remove to skip that role)
GENERATOR_MODEL=gpt-5-mini
JUDGE_MODEL=gpt-5
PREP_MODEL=gpt-5-mini

# Optional settings (defaults shown)
# REQUEST_TIMEOUT_S=120
# RANDOM_SEED=42
# TRAIN_RATIO=0.7
# MOCK_LLM=0

# Evaluation cap (unset = unlimited)
# MAX_EVALUATIONS=100
# Legacy name still works: MAX_EXPERIMENTS=100
